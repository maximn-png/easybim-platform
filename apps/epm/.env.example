# Clerk (get from apps/portal/.env.local — shared keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk satellite config (EPM is a satellite of portal)
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=localhost:3002
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/sign-in

# Portal URL (for auth redirects)
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# MongoDB
MONGODB_URI=

# Admin user IDs (comma-separated Clerk userIds allowed to create/edit projects)
ADMIN_USER_IDS=

# Autodesk Platform Services (APS) — 2-legged (used for token auth)
APS_CLIENT_ID=
APS_CLIENT_SECRET=

# APS 3-legged OAuth callback URL — must also be registered in APS app console
# Local: http://localhost:3002/api/auth/autodesk/callback
# Prod:  https://epm.easybim.co.il/api/auth/autodesk/callback
APS_CALLBACK_URL=

# ── Gmail draft export (Export Report → "אשר ופתח ב-Gmail") ──────────────────
# No env vars needed in EPM — Gmail access comes through Clerk's Google social
# connection. One-time setup (dashboards, not code):
#
# 1. Google Cloud Console (reuse the existing project, #117471045751):
#    - Enable the **Gmail API**.
#    - OAuth consent screen → User type **Internal** (works because easybim.co.il
#      is a Google Workspace; the sensitive gmail.compose scope then needs NO
#      Google verification).
#    - Create credentials → OAuth client ID → **Web application** ("EasyBIM Clerk").
#      Add the redirect URI that Clerk shows in step 2. Copy the client ID/secret.
#
# 2. Clerk Dashboard (shared instance for portal + epm):
#    - User & Authentication → Social Connections → **Google** → enable.
#    - Use **custom credentials**: paste the Web client ID + secret from step 1.
#    - Add additional scope: https://www.googleapis.com/auth/gmail.compose
#    - Copy Clerk's redirect URI back into the Google client's authorized URIs.
#    - Enable Google on sign-in and allow existing users to connect Google.
#
# 3. Users sign in with / connect Google and consent to the Gmail-draft permission.
#    (The existing GOOGLE_CLIENT_ID/SECRET used for Google Photos is a separate
#    Desktop client — do NOT reuse it here.)
