# ─────────────────────────────────────────────────────────────
# Shared across all apps — Clerk Authentication
# Get these from https://dashboard.clerk.com
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─────────────────────────────────────────────────────────────
# Portal app (apps/portal) — apps/portal/.env.local
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# URL of the newsletter app — localhost in dev, production URL in prod
NEXT_PUBLIC_NEWSLETTER_URL=http://localhost:3001

# Google Photos (employee gallery on dashboard)
# Run: node scripts/get-google-photos-token.mjs to generate the refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Share token from the Google Photos album URL (photos.google.com/share/{token})
GOOGLE_PHOTOS_SHARE_TOKEN=

# ─────────────────────────────────────────────────────────────
# Newsletter app (apps/newsletter) — apps/newsletter/.env.local
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_IS_SATELLITE=true
NEXT_PUBLIC_CLERK_DOMAIN=localhost:3001   # in prod: your newsletter production domain
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=http://localhost:3000/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=http://localhost:3001/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=http://localhost:3001/dashboard

# URL of the portal app — localhost in dev, production URL in prod
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/bim-newsletter
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/bim-newsletter

# Encryption key for API keys stored in MongoDB (AES-256-GCM) — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=<32-byte hex key>

# AI APIs — can also be stored per-user in MongoDB via the Settings page
GEMINI_API_KEY=
COHERE_API_KEY=

# QA / testing
QA_TEST_EMAIL=
QA_TEST_PASSWORD=
