# ─────────────────────────────────────────────────────────────
# Shared across all apps — Clerk Authentication
# Get these from https://dashboard.clerk.com
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─────────────────────────────────────────────────────────────
# Portal app (apps/portal) only
# ─────────────────────────────────────────────────────────────
# URL of the newsletter app — localhost during dev, Vercel URL in prod
NEXT_PUBLIC_NEWSLETTER_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────
# Newsletter app (apps/newsletter) only
# ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxx.mongodb.net/bim-newsletter
ENCRYPTION_SECRET=<32-byte hex key>
GEMINI_API_KEY=
COHERE_API_KEY=

# ─────────────────────────────────────────────────────────────
# Portal app — Google Photos (dashboard employee gallery)
# Run: node scripts/get-google-photos-token.mjs to generate the token
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Share token from the Google Photos album URL (photos.google.com/share/{token})
GOOGLE_PHOTOS_SHARE_TOKEN=
